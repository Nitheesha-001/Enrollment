managed implementation in class zbp_uj_cont_i unique;
strict ( 2 );
with draft;
define behavior for ZUJ_CONT_I alias Contract
persistent table zuj_cont
draft table zuj_cont_d
lock master
total etag last_changed_at
authorization master ( global, instance )
{
  create ( authorization : global );
  update;
  delete;

  field ( readonly ) bpnumber, modelnumber, serialnumber;
  field ( mandatory ) status, enrolledon;
  //  Actions
  action ( features : instance ) CancelEnrollment result [1] $self;
  action ( features : instance ) SuspendEnrollment parameter ZUJ_CONT_SUSPEND_P result [1] $self;
  action ( features : instance ) ReactivateEnrollment result [1] $self;
  //  Validations
  validation ValidateStatus on save { field status; }
  validation ValidateSuspendDates on save { field suspend_start, suspend_end; }
  validation ValidateCancelDate on save { field cancelledon; }

  //Determinations
  determination SetInitialStatus on modify { field enrolledon; }
  determination SetCancelledOn on modify { field status; }
  determination ClearSuspendDates on modify { field status; }

  draft action Activate optimized;
  draft action Discard;
  draft action Edit;
  draft action Resume;
  draft determine action Prepare
  {
    validation ValidateStatus;
    validation ValidateSuspendDates;
    validation ValidateCancelDate;
  }

  mapping for zuj_cont corresponding
    {
      bpnumber              = bpnumber;
      modelnumber           = modelnumber;
      serialnumber          = serialnumber;
      country               = country;
      enrolledon            = enrolledon;
      cancelledon           = cancelledon;
      status                = status;
      suspend_start         = suspend_start;
      suspend_end           = suspend_end;
      last_changed_at       = last_changed_at;
      local_last_changed_at = local_last_changed_at;
    }

  mapping for zuj_bp
    {
      firstname = firstname;
      lastname  = lastname;
      email     = email;
    }

  mapping for zuj_addr
    {
      street1 = street1;
      street2 = street2;
      city    = city;
      state   = state;
      country = country;
      zipcode = zipcode;
    }
}